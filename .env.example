# Servidor
PORT=3001
NODE_ENV=development
APP_API_PREFIX=/api/v1

# Quantos processos Node subir (usa todos os núcleos). Vazio = nº de CPUs do
# container. Ponha 1 para desligar o cluster (VPS de 1 core ou debug).
WEB_CONCURRENCY=

# Banco de Dados
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bankerpro_db
DB_LOGGING=true

# Pool de conexões POR WORKER. O total = WEB_CONCURRENCY x DB_POOL_MAX precisa
# caber no max_connections do Postgres (default 100). Ex.: 4 workers x 15 = 60.
DB_POOL_MAX=15
DB_POOL_MIN=2

# ─────────────────────────────────────────────────
# Redis / Fila (análise de áudio assíncrona)
# ─────────────────────────────────────────────────
# Deixe VAZIO para desligar a fila: a análise de áudio roda de forma síncrona,
# como antes. Preencha para ativar o processamento em segundo plano.
# Use REDIS_URL (recomendado) OU os campos separados abaixo.
REDIS_URL=
# Alternativa aos campos separados (usados só se REDIS_URL estiver vazio):
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
# Quantas análises de áudio processam ao mesmo tempo. O freio que impede uma
# rajada de saturar a máquina. Numa VPS de 2 núcleos, 1 ou 2 é o recomendado.
AUDIO_WORKER_CONCURRENCY=2

# Limites de requisição por usuário/minuto nos endpoints que gastam dinheiro.
# Generosos: só um loop/abuso bate no teto. Protegem a fatura de IA e a máquina.
RATE_LIMIT_AI=40
RATE_LIMIT_AUDIO=10

# JWT
JWT_SECRET=super_secret_jwt_key_bankerpro_change_me_in_production
JWT_EXPIRES_IN=7d

# Integrações de Terceiros
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Só para transcrever o áudio da Análise de Áudio (a Anthropic não recebe áudio).
OPENAI_API_KEY=your_openai_api_key_here
MP_ACCESS_TOKEN=your_mercado_pago_access_token_here
MP_PUBLIC_KEY=your_mercado_pago_public_key_here
MP_CLIENT_ID=your_mercado_pago_client_id_here
MP_CLIENT_SECRET=your_mercado_pago_client_secret_here
MP_WEBHOOK_SECRET=your_mercado_pago_webhook_secret_here
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
# Z-API (WhatsApp) — dados da instância no painel https://app.z-api.io
# A URL da sua instância tem o formato:
#   https://api.z-api.io/instances/{ZAPI_INSTANCE_ID}/token/{ZAPI_INSTANCE_TOKEN}/send-text
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
# "Token de segurança da conta" (Segurança > Token). Vai no header Client-Token.
# Deixe vazio se o token de segurança estiver desligado na conta.
ZAPI_CLIENT_TOKEN=
# Só mude se usar um domínio próprio/on-premise da Z-API.
ZAPI_BASE_URL=https://api.z-api.io

# URL pública desta API (sem barra no final). Usada para registrar o webhook do
# WhatsApp automaticamente no boot, sem precisar abrir a tela de status.
# Ex.: https://bankerpro-bankerpro--api.wohb2u.easypanel.host
APP_PUBLIC_URL=

# Token do Agente Codex (IA Desenvolvedora externa)
CODEX_TOKEN=codex_developer_secret_key_123456
