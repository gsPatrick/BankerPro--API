# Servidor
PORT=3001
NODE_ENV=development
APP_API_PREFIX=/api/v1

# Quantos processos Node subir (usa todos os núcleos). Vazio = nº de CPUs do
# container. Ponha 1 para desligar o cluster (VPS de 1 core ou debug).
WEB_CONCURRENCY=

# Banco de Dados
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bankerpro_db
DB_LOGGING=true

# Pool de conexões POR WORKER. O total = WEB_CONCURRENCY x DB_POOL_MAX precisa
# caber no max_connections do Postgres (default 100). Ex.: 4 workers x 15 = 60.
DB_POOL_MAX=15
DB_POOL_MIN=2

# JWT (Para uso futuro)
JWT_SECRET=super_secret_jwt_key_bankerpro_change_me_in_production
JWT_EXPIRES_IN=7d

# Integrações de Terceiros (Para uso futuro)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MP_ACCESS_TOKEN=your_mercado_pago_access_token_here
MP_PUBLIC_KEY=your_mercado_pago_public_key_here
MP_CLIENT_ID=your_mercado_pago_client_id_here
MP_CLIENT_SECRET=your_mercado_pago_client_secret_here
MP_WEBHOOK_SECRET=your_mercado_pago_webhook_secret_here
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here

# Token do Agente Codex (IA Desenvolvedora externa)
CODEX_TOKEN=codex_developer_secret_key_123456
